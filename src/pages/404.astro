---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
---

<Base title="Not found" description="That page doesn't exist.">
	<section class="container notfound">
		<span class="eyebrow">404</span>
		<h1>This page <span class="serif">wandered off</span>.</h1>
		<p>The link's broken or the page moved. Let's get you back.</p>
		<a class="btn-primary" href="/">
			<Icon name="arrow-right" size={17} />
			Back home
		</a>
	</section>
</Base>

<style>
	.notfound {
		min-height: 70vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: flex-start;
		gap: 1.1rem;
		padding-block: 4rem;
	}
	.notfound h1 {
		font-size: clamp(2.2rem, 6vw, 3.6rem);
	}
	.notfound p {
		color: var(--muted);
		font-size: 1.05rem;
	}
	.notfound .btn-primary {
		margin-top: 0.5rem;
	}
</style>
