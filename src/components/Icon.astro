---
type IconName =
	| 'github'
	| 'gitlab'
	| 'discord'
	| 'mail'
	| 'globe'
	| 'copy'
	| 'arrow-right'
	| 'arrow-up-right'
	| 'arrow-down'
	| 'sun'
	| 'moon'
	| 'sparkles';

interface Props {
	name: IconName;
	class?: string;
	size?: number;
}

const { name, class: className, size = 20 } = Astro.props;

const stroked: Partial<Record<IconName, string>> = {
